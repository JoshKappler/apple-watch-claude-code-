{
  "name": "pinch",
  "version": "0.1.0",
  "private": true,
  "description": "Claude Code on your wrist — drive a full agentic coding session from an Apple Watch Ultra over cellular.",
  "workspaces": [
    "packages/protocol",
    "backend",
    "simulator"
