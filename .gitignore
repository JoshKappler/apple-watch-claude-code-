DerivedData/
build/
*.xcworkspace/xcuserdata/
.swiftpm/
# Generated by XcodeGen from watch/project.yml — project.yml is the source of truth.
*.xcodeproj/
# Pairing secret (server URL + RCE token), shared by the watch + phone apps.
# Template is watch/Secrets.example.swift.
watch/Sources/Shared/Secrets.swift
# (legacy pre-shared-core location, still ignored so an old checkout never commits it)
watch/Sources/Secrets.swift
# Regenerated on every build by the "Generate BuildStamp" preBuildScript (git SHA + timestamp,
# compiled into the binary so a flash is self-verifying via Settings → Build). Never committed.
watch/Sources/Shared/BuildStamp.swift

# Cloudflare tunnel creds
*.cloudflared.json
cert.pem

# Local runtime state
state/
sessions/
# Durable session-resume records (our id → SDK id), written by backend/src/sessionStore.ts
.pinch-sessions.json
.pinch-sessions.json.tmp

# Claude Code local runtime artifacts
.claude/
