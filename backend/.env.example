# Anthropic credentials — read directly by the Claude Agent SDK.
# Not required when PINCH_MOCK=1.
ANTHROPIC_API_KEY=

# Bearer token the watch/simulator must present to connect.
# Generate a strong random one with: node infra/scripts/gen-token.mjs
# (or run ./setup.sh, which fills this in for you). Treat it like an SSH key.
PINCH_TOKEN=

# WebSocket server port. Path is always /ws.
PORT=8787

# Comma-separated absolute repo paths the agent is allowed to operate in (allowlist).
# The first entry is the default project. Paths outside these roots are rejected.
PINCH_PROJECTS=/abs/path/to/repo1,/abs/path/to/repo2

# 1 = scripted mock agent (no SDK, no API key). 0 = real Claude Agent SDK.
PINCH_MOCK=0

# Model id passed to the SDK.
PINCH_MODEL=claude-opus-4-8

# pino log level: trace|debug|info|warn|error|fatal
LOG_LEVEL=info
